{
  "name": "longbow-cli",
  "version": "0.1.0",
  "description": "Self-custodial terminal client for the Longbow protocol on Robinhood Chain. Your private key never leaves your machine.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "longbow",
    "robinhood-chain",
    "ethereum",
    "defi",
    "cli"
  ],
  "homepage": "https://github.com/Longbow-Finance/longbow#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Longbow-Finance/longbow.git",
    "directory": "cli"
  },
  "bin": {
    "longbow": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "binaries": "npm run build:win && npm run build:linux && npm run build:mac && npm run build:mac-arm",
    "build:win": "bun build src/index.ts --compile --minify --target=bun-windows-x64 --outfile dist/bin/longbow-windows-x64.exe",
    "build:linux": "bun build src/index.ts --compile --minify --target=bun-linux-x64 --outfile dist/bin/longbow-linux-x64",
    "build:mac": "bun build src/index.ts --compile --minify --target=bun-darwin-x64 --outfile dist/bin/longbow-macos-x64",
    "build:mac-arm": "bun build src/index.ts --compile --minify --target=bun-darwin-arm64 --outfile dist/bin/longbow-macos-arm64"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1",
    "viem": "^2.55.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
