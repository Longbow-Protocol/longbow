# Copy to .env.local and fill in after deploying the contracts.

# Deployed contract addresses on Robinhood Chain (chain id 4663).
NEXT_PUBLIC_POSITION_MANAGER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LONG_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ORACLE=0x0000000000000000000000000000000000000000

# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Injected wallets (MetaMask etc.) work without it, but WalletConnect needs it.
NEXT_PUBLIC_WC_PROJECT_ID=

# Optional RPC override (defaults to the public Robinhood Chain RPC).
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com
